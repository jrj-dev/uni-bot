# Core UniFi API access used by local scripts.
UNIFI_BASE_URL=https://unifi.local
UNIFI_API_KEY=replace-me-locally

# Optional SSH settings for guarded UniFi log collection.
UNIFI_SSH_USERNAME=
UNIFI_SSH_PRIVATE_KEY_PATH=
UNIFI_SSH_PRIVATE_KEY=
UNIFI_SSH_PASSWORD=
UNIFI_SSH_APPROVAL_SECRET=

# Optional Loki access for local log queries and webhook forwarding.
LOKI_BASE_URL=http://your-loki-hostname-or-ip:3100
LOKI_API_KEY=replace-me-if-needed

# Optional local LM Studio settings for script-side testing helpers.
LM_STUDIO_BASE_URL=http://your-lmstudio-hostname-or-ip:1234
LM_STUDIO_API_KEY=replace-me
LM_STUDIO_MODEL=

# Optional allowlists for guarded policy toggles.
UNIFI_GUARD_ALLOWED_ACL_RULE_IDS=
UNIFI_GUARD_ALLOWED_FIREWALL_POLICY_IDS=
UNIFI_GUARD_ALLOWED_DNS_POLICY_IDS=

# Optional UniFi alarm webhook receiver settings.
UNIFI_ALARM_WEBHOOK_BIND=0.0.0.0
UNIFI_ALARM_WEBHOOK_PORT=8787
UNIFI_ALARM_WEBHOOK_PATH=/webhook/unifi/alarm
UNIFI_ALARM_WEBHOOK_SECRET=
UNIFI_ALARM_LOKI_JOB=unifi_siem

# Optional UniFi event poller settings.
UNIFI_EVENT_PATH=/proxy/network/v2/api/site/default/event
UNIFI_EVENT_LIMIT=50
UNIFI_POLL_INTERVAL_SECONDS=30
UNIFI_EVENT_TIMEOUT_SECONDS=20
UNIFI_EVENT_LOKI_JOB=unifi_siem
UNIFI_INSECURE=true
LOKI_INSECURE=false
